GOOGLE_APPLICATION_CREDENTIALS=.secrets/codex-icp-engine-k2-demo-483116.json
GOOGLE_CLOUD_PROJECT=k2-demo-483116
GOOGLE_CLOUD_LOCATION=global
GEMINI_MODEL=gemini-3.5-flash
GEMINI_THINKING_BUDGET=0

# Agentic GTM dashboard
ICP_APP_STATE_DIR=out/app_state
ICP_CRITERIA_PATH=icp.md
ICP_SEARCH_PROVIDER=duckduckgo-html
ICP_ADMIN_TOKEN=
ICP_ALLOW_OPEN_API=false

# Claude qualifier (LLM judge). Enable via the "qualifier" setting = "claude".
# Requires the optional extra: pip install -e ".[claude]"
ANTHROPIC_API_KEY=
ICP_CLAUDE_MODEL=claude-haiku-4-5-20251001
ICP_CLAUDE_MAX_TOKENS=1024

# Research-grade discovery (Perplexity Sonar). Enable via the "discovery_provider"
# setting = "perplexity" (or "auto", which uses Perplexity when this key is set and
# otherwise falls back to Serper -> DuckDuckGo). Hand-rolled stdlib client; no extra.
PERPLEXITY_API_KEY=
ICP_PERPLEXITY_MODEL=sonar
ICP_PERPLEXITY_MAX_TOKENS=1024

# Optional enrichment and retrieval providers. Do not commit real values.
APOLLO_API_KEY=
K2_API_KEY=
K2_BASE_URL=https://api.knowledge2.ai
K2_RESEARCH_CORPUS_ID=
K2_DEBUG=false
GITHUB_TOKEN=

# Cloudflare Worker deploy helper. Do not commit real token values.
CLOUDFLARE_ACCOUNT_ID=
ICP_API_ORIGIN=
ICP_CLOUDFLARE_ROUTE=gtm-dev.knowledge2.ai
